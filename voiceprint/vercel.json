{
  "version": 2,
  "builds": [
    { "src": "voiceprint/public/index.html", "use": "@vercel/static" },
    { "src": "voiceprint/api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/voiceprint/api/$1" },
    { "src": "/(.*)", "dest": "/voiceprint/public/$1" }
  ]
}
